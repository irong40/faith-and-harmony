    {
      "parameters": {
        "jsCode": "// Select top 2-3 images by QA score for watermark previews\nconst jobId = $json.job_id;\nconst supabaseUrl = $env.SUPABASE_URL;\nconst serviceKey = $env.SUPABASE_SERVICE_KEY;\n\ntry {\n  const resp = await fetch(\n    `${supabaseUrl}/rest/v1/drone_assets?mission_id=eq.${jobId}&processing_status=in.(processed,exported)&file_type=eq.image&order=qa_score.desc&limit=3`,\n    {\n      headers: {\n        'apikey': serviceKey,\n        'Authorization': `Bearer ${serviceKey}`\n      }\n    }\n  );\n  const candidates = await resp.json();\n\n  if (!candidates || candidates.length === 0) {\n    return [{ json: { ...$json, watermark_candidates: [], watermark_skipped: true } }];\n  }\n\n  return [{ json: { ...$json, watermark_candidates: candidates, watermark_skipped: false } }];\n} catch (e) {\n  return [{ json: { ...$json, watermark_candidates: [], watermark_skipped: true, watermark_error: e.message } }];\n}"
      },
      "id": "select-preview-images",
      "name": "Select Preview Images",
