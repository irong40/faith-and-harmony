    {
      "parameters": {
        "jsCode": "// QA gate: for mapping jobs auto-pass, otherwise check processed quality\nconst body = $json;\nconst path = body.processing_path;\n\n// Mapping data is validated differently - auto pass\nif (path === 'C') {\n  return [{ json: { ...body, qa_gate_passed: true, qa_gate_reason: 'mapping_auto_pass' } }];\n}\n\n// For photo processing, verify we have processed files\nconst profile = body.processing_profile || {};\nconst threshold = profile.qa_threshold || 70;\nconst qaScore = body.qa_score || 0;\n\nconst passed = qaScore >= threshold;\nreturn [{ json: { ...body, qa_gate_passed: passed, qa_gate_reason: passed ? 'score_above_threshold' : `qa_score ${qaScore} below threshold ${threshold}` } }];"
      },
