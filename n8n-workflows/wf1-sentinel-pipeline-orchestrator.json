    {
      "parameters": {
        "jsCode": "// Verify all asset file paths are accessible\nconst body = $('Webhook Trigger').item.json.body;\nconst assets = body.assets || [];\nconst supabaseUrl = $env.SUPABASE_URL;\nconst results = [];\n\nfor (const asset of assets) {\n  const url = asset.file_path.startsWith('http')\n    ? asset.file_path\n    : `${supabaseUrl}/storage/v1/object/public/drone-jobs/${asset.file_path}`;\n  \n  try {\n    const resp = await fetch(url, { method: 'HEAD' });\n    results.push({\n      asset_id: asset.id,\n      file_name: asset.file_name,\n      accessible: resp.ok,\n      status: resp.status\n    });\n  } catch (e) {\n    results.push({\n      asset_id: asset.id,\n      file_name: asset.file_name,\n      accessible: false,\n      error: e.message\n    });\n  }\n}\n\nconst allAccessible = results.every(r => r.accessible);\nconst failedCount = results.filter(r => !r.accessible).length;\n\nreturn [{\n  json: {\n    ...body,\n    file_detect_results: results,\n    file_detect_passed: allAccessible,\n    file_detect_failed_count: failedCount\n  }\n}];"
      },
      "id": "file-detect",
      "name": "File Detect Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
