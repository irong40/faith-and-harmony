    {
      "parameters": {
        "jsCode": "// Coverage check: compare asset coverage_tags against shot_requirements\nconst body = $('Webhook Trigger').item.json.body;\nconst assets = body.assets || [];\nconst profile = body.processing_profile || {};\nconst shotReqs = profile.shot_requirements || {};\n\n// Get coverage tags from assets (fetched during EXIF extraction)\nconst coveredTags = new Set();\nfor (const a of assets) {\n  if (a.coverage_tag) coveredTags.add(a.coverage_tag);\n}\n\nconst required = Object.keys(shotReqs);\nconst missing = required.filter(r => !coveredTags.has(r));\nconst passed = missing.length === 0;\n\nreturn [{\n  json: {\n    ...body,\n    coverage_passed: passed,\n    coverage_missing: missing,\n    coverage_covered: [...coveredTags]\n  }\n}];"
      },
      "id": "coverage-logic",
      "name": "Coverage Check Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 200]
