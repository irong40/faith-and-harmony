      "id": "if-has-previews",
      "name": "Has Preview Candidates?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [6160, -200]
    },
    {
      "parameters": {
        "jsCode": "// Build watermark commands for each candidate image\n// Uses ImageMagick on the processing rig\nconst candidates = $json.watermark_candidates || [];\nconst jobId = $json.job_id;\nconst supabaseUrl = $env.SUPABASE_URL;\nconst serviceKey = $env.SUPABASE_SERVICE_KEY;\nconst watermarkTile = '/opt/sentinel/assets/watermark-tile.png';\nconst previewUrls = [];\n\nfor (let i = 0; i < candidates.length; i++) {\n  const asset = candidates[i];\n  const idx = String(i + 1).padStart(2, '0');\n  const inputPath = `/tmp/watermark_input_${jobId}_${idx}.jpg`;\n  const outputPath = `/tmp/watermark_output_${jobId}_${idx}.jpg`;\n  const storagePath = `${jobId}/preview_${idx}.jpg`;\n\n  // Download original from private drone-jobs bucket using signed URL\n  const signResp = await fetch(\n    `${supabaseUrl}/storage/v1/object/sign/drone-jobs/${asset.source_path || asset.file_path}`,\n    {\n      method: 'POST',\n      headers: {\n        'apikey': serviceKey,\n        'Authorization': `Bearer ${serviceKey}`,\n        'Content-Type': 'application/json'\n      },\n      body: JSON.stringify({ expiresIn: 300 })\n    }\n  );\n  const signData = await signResp.json();\n  const downloadUrl = `${supabaseUrl}/storage/v1${signData.signedURL}`;\n\n  // Download to local file\n  const dlResp = await fetch(downloadUrl);\n  const buffer = Buffer.from(await dlResp.arrayBuffer());\n  const fs = require('fs');\n  fs.writeFileSync(inputPath, buffer);\n\n  // Resize, strip EXIF, apply watermark overlay\n  const { execSync } = require('child_process');\n  execSync(`magick \"${inputPath}\" -resize 1200x -strip \"${inputPath}_resized.jpg\"`);\n  execSync(`magick \"${inputPath}_resized.jpg\" \"${watermarkTile}\" -gravity center -compose dissolve -define compose:args=35 -composite \"${outputPath}\"`);\n\n  // Upload to watermark-previews bucket\n  const previewData = fs.readFileSync(outputPath);\n  const uploadResp = await fetch(\n    `${supabaseUrl}/storage/v1/object/watermark-previews/${storagePath}`,\n    {\n      method: 'POST',\n      headers: {\n        'apikey': serviceKey,\n        'Authorization': `Bearer ${serviceKey}`,\n        'Content-Type': 'image/jpeg',\n        'x-upsert': 'true'\n      },\n      body: previewData\n    }\n  );\n\n  // Build public URL\n  const publicUrl = `${supabaseUrl}/storage/v1/object/public/watermark-previews/${storagePath}`;\n  previewUrls.push(publicUrl);\n\n  // Cleanup temp files\n  try {\n    fs.unlinkSync(inputPath);\n    fs.unlinkSync(`${inputPath}_resized.jpg`);\n    fs.unlinkSync(outputPath);\n  } catch (e) { /* ignore cleanup errors */ }\n}\n\nreturn [{ json: { ...$json, preview_urls: previewUrls, watermark_count: previewUrls.length } }];"
      },
