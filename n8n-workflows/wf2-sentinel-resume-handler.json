        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  job_id: $json.mission_id,\n  job_number: $json.job?.job_number,\n  package_code: $json.job?.drone_packages?.code,\n  property_address: $json.job?.property_address,\n  client_email: $json.job?.customers?.email,\n  client_name: $json.job?.customers?.name,\n  include_social_exports: ['PHOTO_VIDEO_795', 'PREMIUM_1250'].includes($json.job?.drone_packages?.code),\n  include_raw_files: $json.job?.processing_profile?.raw_workflow || false,\n  include_technical_data: false\n}) }}",
        "options": { "timeout": 30000 }
