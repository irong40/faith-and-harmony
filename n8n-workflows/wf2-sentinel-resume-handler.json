    {
      "parameters": {
        "jsCode": "// Coverage review resume: re-check coverage tags vs requirements\nconst trigger = $('Webhook Trigger').item.json.body;\nconst jobData = $('Fetch Job State').item.json;\nconst job = Array.isArray(jobData) ? jobData[0] : jobData;\nconst assets = $('Fetch Active Assets').item.json;\nconst assetList = Array.isArray(assets) ? assets : [assets];\n\nconst profile = job.processing_profile || {};\nconst shotReqs = profile.shot_requirements || {};\nconst required = Object.keys(shotReqs);\n\nconst coveredTags = new Set();\nfor (const a of assetList) {\n  if (a.coverage_tag) coveredTags.add(a.coverage_tag);\n}\n\nconst missing = required.filter(r => !coveredTags.has(r));\nconst passed = missing.length === 0;\n\nreturn [{\n  json: {\n    mission_id: trigger.mission_id,\n    hold_type: 'coverage_review',\n    coverage_passed: passed,\n    missing_shots: missing,\n    covered: [...coveredTags],\n    job: job\n  }\n}];"
      },
