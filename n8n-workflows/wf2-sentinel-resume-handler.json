    {
      "parameters": {
        "rules": {
          "values": [
            { "outputIndex": 0, "value": "qa_review" },
            { "outputIndex": 1, "value": "coverage_review" }
          ]
        },
        "dataPropertyName": "={{ $('Webhook Trigger').item.json.body.hold_type }}",
        "fallbackOutput": 0
      },
      "id": "route-hold-type",
      "name": "Route by Hold Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "jsCode": "// QA Review resume: re-check remaining non-excluded assets\nconst trigger = $('Webhook Trigger').item.json.body;\nconst jobData = $('Fetch Job State').item.json;\nconst job = Array.isArray(jobData) ? jobData[0] : jobData;\nconst assets = $('Fetch Active Assets').item.json;\nconst assetList = Array.isArray(assets) ? assets : [assets];\n\n// Get processing template QA threshold\nconst profile = job.processing_profile || {};\nconst threshold = profile.qa_threshold || 70;\n\n// Calculate average QA score of non-excluded assets\nconst scores = assetList\n  .filter(a => a.qa_score != null)\n  .map(a => a.qa_score);\nconst avgScore = scores.length > 0\n  ? scores.reduce((sum, s) => sum + s, 0) / scores.length\n  : 0;\n\nconst passed = avgScore >= threshold;\n\nreturn [{\n  json: {\n    mission_id: trigger.mission_id,\n    hold_type: 'qa_review',\n    qa_passed: passed,\n    avg_score: Math.round(avgScore * 10) / 10,\n    threshold: threshold,\n    asset_count: assetList.length,\n    job: job\n  }\n}];"
      },
      "id": "qa-review-logic",
      "name": "QA Review Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "qa-resume-pass",
              "leftValue": "={{ $json.qa_passed }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-qa-resume-pass",
