        [{ "node": "Package OK?", "type": "main", "index": 0 }]
      ]
    },
    "Package OK?": {
      "main": [
        [{ "node": "Step 7 Start - Delivery", "type": "main", "index": 0 }],
        [{ "node": "Set Job Failed", "type": "main", "index": 0 }]
      ]
    },
    "Step 7 Start - Delivery": {
      "main": [
        [{ "node": "Insert Delivery Log", "type": "main", "index": 0 }]
      ]
    },
    "Insert Delivery Log": {
