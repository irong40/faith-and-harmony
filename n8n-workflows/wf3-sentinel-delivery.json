        [{ "node": "Set Job Delivered", "type": "main", "index": 0 }]
      ]
    },
    "Set Job Delivered": {
      "main": [
        [{ "node": "Mark Notification Sent", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [{ "name": "sentinel" }, { "name": "pipeline" }]
}
