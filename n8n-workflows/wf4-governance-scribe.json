      },
      "id": "gs-0009",
      "name": "Query previous scribe output",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 1000]
    },
    {
      "parameters": {
        "jsCode": "const quarterData = $('Determine Quarter').first().json;\nconst droneJobs = $('Query drone_jobs').first().json;\nconst decisions = $('Query governance_decisions').first().json;\nconst obligations = $('Query compliance_obligations').first().json;\nconst financials = $('Query financial_actuals').first().json;\nconst govLog = $('Query governance_log').first().json;\nconst prevScribe = $('Query previous scribe output').first().json;\n\n// Handle Supabase REST responses (arrays)\nconst droneJobsArr = Array.isArray(droneJobs) ? droneJobs : [];\nconst decisionsArr = Array.isArray(decisions) ? decisions : [];\nconst obligationsArr = Array.isArray(obligations) ? obligations : [];\nconst financialsArr = Array.isArray(financials) ? financials : [];\nconst govLogArr = Array.isArray(govLog) ? govLog : [];\nconst prevScribeArr = Array.isArray(prevScribe) ? prevScribe : [];\n\nreturn [{\n  json: {\n    quarter: quarterData.quarter,\n    fiscalYear: quarterData.fiscalYear,\n    quarterStart: quarterData.quarterStart,\n    quarterEnd: quarterData.quarterEnd,\n    collectedData: {\n      drone_jobs: droneJobsArr,\n      governance_decisions: decisionsArr,\n      compliance_obligations: obligationsArr,\n      financial_actuals: financialsArr,\n      governance_log: govLogArr,\n      previous_scribe_output: prevScribeArr.length > 0 ? prevScribeArr[0] : null\n    }\n  }\n}];"
      },
      "id": "gs-0010",
      "name": "Merge Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 400]
    }
  ],
