LIGHTROOM_EXPORT_DIR=C:\Users\redle\Pictures\LR_Export

# Construction label font
LABEL_FONT_PATH=C:\Windows\Fonts\arial.ttf

# Temp directory (optional, defaults to ~/.sentinel_tmp)
# TEMP_DIR=C:\Users\redle\.sentinel_tmp

# Callback timeout in seconds (default 3600 = 1 hour)
# CALLBACK_TIMEOUT=3600
